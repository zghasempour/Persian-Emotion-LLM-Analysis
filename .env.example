# Copy this file to ".env" and fill in only the keys you have.
# ALL keys are OPTIONAL — the harness runs whichever providers you configure
# and skips the rest. Local Ollama models need no key at all.
#
# Load them into your shell with:  set -a; source .env; set +a
# IMPORTANT: .env is gitignored. Never commit real keys.

# One key for many cutting-edge cloud models (GPT / Claude / Gemini / Qwen / Llama)
OPENROUTER_API_KEY=

# Claude, directly from Anthropic
ANTHROPIC_API_KEY=

# Google Gemini — FREE tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — FREE, very fast open models: https://console.groq.com/keys
GROQ_API_KEY=
